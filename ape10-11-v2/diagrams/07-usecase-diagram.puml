@startuml
skinparam backgroundColor #FAFBFC
left to right direction

actor "Usuario" as User

rectangle "Compilador APE10-11 v2" {
  usecase "Compilar código\nPOST /api/compile" as UC1
  usecase "Cargar ejemplo" as UC2
  usecase "Ver tokens" as UC3
  usecase "Ver AST" as UC4
  usecase "Ver tabla de\nsímbolos" as UC5
  usecase "Compilar vía\nWebSocket" as UC6
}

User --> UC1
User --> UC2
User --> UC3
User --> UC4
User --> UC5
User --> UC6

UC1 ..> UC3 : <<include>>
UC1 ..> UC4 : <<include>>
UC1 ..> UC5 : <<include>>
@enduml
