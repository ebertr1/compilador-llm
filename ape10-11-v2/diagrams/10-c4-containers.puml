@startuml
!define PERSON rectangle
!define CONTAINER rectangle
!define SYSTEM_BOUNDARY rectangle
skinparam backgroundColor #FAFBFC

PERSON "Usuario" as User #89B4FA

SYSTEM_BOUNDARY "Sistema Compilador APE10-11 v2" as System {
  CONTAINER "React SPA\n[Vite + Monaco]" as Web #A6E3A1
  CONTAINER "API Gateway\n[Spring Boot :8080]" as Gateway #CBA6F7
  CONTAINER "Semantic Service\n[Spring Boot :8083]\nREST + WebSocket" as Semantic #F9E2AF
  CONTAINER "Lexical Service\n[Spring Boot :8081]" as Lexical #A6E3A1
  CONTAINER "Syntactic Service\n[Spring Boot :8082]" as Syntactic #F38BA8
}

User --> Web : HTTP
Web --> Gateway : /api/*
Web --> Semantic : /ws/compile
Gateway --> Semantic : POST /compile
Semantic --> Lexical : POST /lex
Semantic --> Syntactic : POST /parse
@enduml
